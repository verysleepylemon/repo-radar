# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── GitHub (optional but recommended to avoid rate-limiting) ─────────────────
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Notifications (at least one recommended) ─────────────────────────────────
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
# TELEGRAM_BOT_TOKEN=123456:ABCdefGHIjklMNOpqrsTUVwxyz
# TELEGRAM_CHAT_ID=-100123456789

# ─── Tuning ───────────────────────────────────────────────────────────────────
SPIKE_THRESHOLD=500          # Stars gained in 24h to trigger an alert
MIN_STARS=50                 # Minimum total stars to consider a repo
POLL_INTERVAL_SECS=300       # How often to poll GitHub / HN (seconds)
DEDUP_TTL_HOURS=6            # Don't re-alert the same repo within this window
