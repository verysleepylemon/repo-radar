# ─── Redis (optional — repo-radar runs without it, just without dedup/history) ─
REDIS_URL=redis://127.0.0.1:6379

# ─── GitHub (optional but recommended to avoid rate-limiting) ─────────────────
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Twitter / X (optional — get a Bearer Token at developer.twitter.com) ─────
# TWITTER_BEARER_TOKEN=AAAAAAA...
# TWITTER_INTERVAL_SECS=900    # How often to scan Twitter (default: 15 min)

# ─── Reddit ───────────────────────────────────────────────────────────────────
# NOTE: Reddit blocked unauthenticated API access in 2023.
# To enable Reddit scanning, register a "script" app at https://www.reddit.com/prefs/apps
# then set these values:
# REDDIT_CLIENT_ID=your_client_id
# REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_MIN_SCORE=100         # Minimum upvotes to surface a Reddit post

# ─── RSS feeds ────────────────────────────────────────────────────────────────
RSS_INTERVAL_SECS=600        # How often to fetch RSS feeds (default: 10 min)

# ─── Notifications (at least one recommended) ─────────────────────────────────
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
# TELEGRAM_BOT_TOKEN=123456:ABCdefGHIjklMNOpqrsTUVwxyz
# TELEGRAM_CHAT_ID=-100123456789
# Note: Windows toast notifications fire automatically for Critical-priority alerts.

# ─── Tuning ───────────────────────────────────────────────────────────────────
SPIKE_THRESHOLD=500          # Stars gained in 24h to trigger an alert
MIN_STARS=50                 # Minimum total stars to consider a repo
POLL_INTERVAL_SECS=300       # How often to poll GitHub / HN (seconds)
DEDUP_TTL_HOURS=6            # Don't re-alert the same repo within this window
